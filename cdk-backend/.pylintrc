# Pylint configuration file for CNS203 E-Commerce Backend
# This configuration disables line-too-long warnings and other common issues
# while maintaining code quality standards for AWS Lambda functions

[MAIN]
# Files or directories to ignore
ignore=CVS,.git,__pycache__,.venv,cdk.out,node_modules

# Use multiple processes to speed up Pylint
jobs=1

# Pickle collected data for later comparisons
persistent=yes

[MESSAGES CONTROL]
# Disable specific pylint warnings that are not critical for this project
# line-too-long: Disabled as requested - allows longer lines for readability
# missing-*-docstring: Disabled for Lambda functions where docstrings may be optional
# too-many-*: Disabled for complex Lambda functions that may need more parameters/variables
# broad-except: Disabled as Lambda functions often need to catch general exceptions
# import-outside-toplevel: Disabled for conditional imports in Lambda functions
disable=line-too-long,
        missing-module-docstring,
        missing-class-docstring,
        missing-function-docstring,
        too-few-public-methods,
        too-many-arguments,
        too-many-locals,
        too-many-branches,
        too-many-statements,
        too-many-instance-attributes,
        import-outside-toplevel,
        broad-except,
        unused-argument,
        no-else-return,
        consider-using-f-string,
        logging-fstring-interpolation

[REPORTS]
# Output format: text, parseable, colorized, json
output-format=text

# Include reports section
reports=no

# Template for message display
msg-template={path}:{line}:{column}: {msg_id}: {msg} ({symbol})

[BASIC]
# Good variable names which should always be accepted
good-names=i,j,k,ex,Run,_,id,pk,db,ui,ok,app,ctx,event,context

# Bad variable names which should always be refused
bad-names=foo,bar,baz,toto,tutu,tata

# Regular expression matching correct function names
function-rgx=[a-z_][a-z0-9_]{2,30}$

# Regular expression matching correct variable names
variable-rgx=[a-z_][a-z0-9_]{2,30}$

# Regular expression matching correct constant names
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__))$

# Regular expression matching correct class names
class-rgx=[A-Z_][a-zA-Z0-9]+$

# Regular expression matching correct module names
module-rgx=(([a-z_][a-z0-9_]*)|([A-Z][a-zA-Z0-9]+))$

[FORMAT]
# Maximum number of characters on a single line (disabled via line-too-long)
max-line-length=120

# Regexp for lines that are allowed to be longer than the limit
ignore-long-lines=^\s*(# )?<?https?://\S+>?$

# Maximum number of lines in a module
max-module-lines=1000

# String used as indentation unit (4 spaces)
indent-string='    '

[LOGGING]
# Logging modules to check for proper format
logging-modules=logging,aws_lambda_powertools

[MISCELLANEOUS]
# List of note tags to consider
notes=FIXME,XXX,TODO,NOTE

[SIMILARITIES]
# Minimum lines number of a similarity
min-similarity-lines=4

# Ignore comments when computing similarities
ignore-comments=yes

# Ignore docstrings when computing similarities
ignore-docstrings=yes

[TYPECHECK]
# List of class names for which member attributes should not be checked
ignored-classes=optparse.Values,thread._local,_thread._local

# List of members which are set dynamically
generated-members=

[VARIABLES]
# Regular expression matching dummy variables
dummy-variables-rgx=(_+[a-zA-Z0-9]*?$)|dummy

# List of additional names supposed to be defined in builtins
additional-builtins=

[CLASSES]
# List of method names used to declare instance attributes
defining-attr-methods=__init__,__new__,setUp

# List of valid names for the first argument in a class method
valid-classmethod-first-arg=cls

[DESIGN]
# Maximum number of arguments for function/method
max-args=10

# Maximum number of locals for function/method body
max-locals=20

# Maximum number of return/yield for function/method body
max-returns=6

# Maximum number of branches for function/method body
max-branches=15

# Maximum number of statements in function/method body
max-statements=60

# Maximum number of attributes for a class
max-attributes=10

# Minimum number of public methods for a class
min-public-methods=1

# Maximum number of public methods for a class
max-public-methods=25

[IMPORTS]
# Deprecated modules which should not be used
deprecated-modules=optparse,tkinter.tix

[EXCEPTIONS]
# Exceptions that will emit a warning when being caught
overgeneral-exceptions=builtins.Exception
