{
	"compilerOptions": {
		// TODO: Lab 4.1 - Update target for optimistic updates
		// Change "es5" to "es2015" to support modern JavaScript features
		// like Set spreading used in optimistic update patterns
		"target": "es2015",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"module": "esnext",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"downlevelIteration": true
	},
	"include": ["src"]
}
