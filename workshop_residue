import json
import os
from uuid import uuid4
from datetime import datetime, timezone
import boto3
from aws_lambda_powertools import Logger, Tracer, Metrics
from aws_lambda_powertools.utilities.data_classes import EventBridgeEvent
from aws_lambda_powertools.utilities.idempotency import idempotent, DynamoDBPersistenceLayer
from decimal import Decimal

logger = Logger()
tracer = Tracer()
metrics = Metrics()

sqs = boto3.client('sqs')
dynamodb = boto3.resource('dynamodb')
cart_table = dynamodb.Table(os.environ['CART_TABLE_NAME'])
orders_table = dynamodb.Table(os.environ['ORDERS_TABLE_NAME'])

class DecimalEncoder(json.JSONEncoder):
    def default(self, o):
        if isinstance(o, Decimal):
            return float(o)
        return super().default(o)

def convert_floats_to_decimal(obj):
    """Recursively convert float values to Decimal for DynamoDB compatibility"""
    if isinstance(obj, dict):
        return {k: convert_floats_to_decimal(v) for k, v in obj.items()}
    elif isinstance(obj, list):
        return [convert_floats_to_decimal(item) for item in obj]
    elif isinstance(obj, float):
        return Decimal(str(obj))
    else:
        return obj

@logger.inject_lambda_context
@tracer.capture_lambda_handler
@metrics.log_metrics(capture_cold_start_metric=True)
@idempotent(persistence_store=DynamoDBPersistenceLayer(table_name=os.environ.get('IDEMPOTENCY_TABLE_NAME', 'idempotency-table')))
def lambda_handler(event, context):
    try:
        eb_event = EventBridgeEvent(event)
        detail = eb_event.detail
        
        user_id = detail['userId']
        checkout_data = detail['body']
        # Convert floats to Decimals for DynamoDB compatibility
        checkout_data = convert_floats_to_decimal(checkout_data)
        logger.info("Processing checkout for user: %s", user_id)

        request_id = detail.get('requestId')
        
        logger.info(f"Processing checkout for user {user_id}")
        
        # Get user's cart
        cart_response = cart_table.get_item(Key={'user_id': user_id})
        if 'Item' not in cart_response:
            raise ValueError("Cart not found")
        
        cart = cart_response['Item']
        if not cart.get('items'):
            raise ValueError("Cart is empty")
        
        # Generate order ID
        order_id = str(uuid4())
        
        # Create initial order record
        order_record = {
            'customer_id': user_id,
            'order_id': order_id,
            'request_id': request_id,
            'items': cart['items'],
            'total_amount': cart['total_amount'],
            'item_count': cart['item_count'],
            'status': 'processing',
            'checkout_data': checkout_data,
            'created_at': datetime.now(timezone.utc).isoformat()
        }
        
        orders_table.put_item(Item=order_record)
        
        # Send to inventory processing queue
        sqs.send_message(
            QueueUrl=os.environ['INVENTORY_QUEUE_URL'],
            MessageBody=json.dumps({
                'order_id': order_id,
                'user_id': user_id,
                'cart': cart,
                'checkout_data': checkout_data,
                'request_id': request_id
            }, cls=DecimalEncoder)
        )
        
        logger.info(f"Checkout initiated for order {order_id}")
        return {'statusCode': 200, 'orderId': order_id}
        
    except Exception as e:
        logger.error(f"Checkout failed: {str(e)}")
        raise

Checkout Event Handler
This checkout handler initiates the order processing workflow by validating that the user has a cart with items, creating an initial order record in Amazon DynamoDB with a unique order ID, and sending the order to the inventory processing queue via Amazon SQS. The function extracts user information from Amazon EventBridge events, performs cart validation, creates a comprehensive order record with all necessary metadata, and triggers the asynchronous processing pipeline. This separation allows complex checkout logic without blocking API responses, enabling sub-100ms checkout confirmations.
