import json
import os
from decimal import Decimal
from datetime import datetime, timezone
import boto3
from aws_lambda_powertools import Logger, Tracer, Metrics
from aws_lambda_powertools.utilities.data_classes import EventBridgeEvent
from aws_lambda_powertools.utilities.idempotency import idempotent, DynamoDBPersistenceLayer
from aws_lambda_powertools.metrics import MetricUnit

logger = Logger()
tracer = Tracer()
metrics = Metrics()

dynamodb = boto3.resource('dynamodb')
eventbridge = boto3.client('events')
cart_table = dynamodb.Table(os.environ['CART_TABLE_NAME'])

class DecimalEncoder(json.JSONEncoder):
    def default(self, o):
        if isinstance(o, Decimal):
            return float(o)
        return super().default(o)

@logger.inject_lambda_context
@tracer.capture_lambda_handler
@metrics.log_metrics(capture_cold_start_metric=True)
@idempotent(persistence_store=DynamoDBPersistenceLayer(table_name=os.environ.get('IDEMPOTENCY_TABLE_NAME', 'idempotency-table')))
def lambda_handler(event, context):
    eb_event = EventBridgeEvent(event)
    detail = eb_event.detail

    logger.info(f"Received event: {json.dumps(eb_event, default=str)}")
    
    # Log the event detail for debugging
    logger.info(f"Received event detail: {json.dumps(detail, default=str)}")
    
    # Handle both structured and unstructured event formats
    if 'userId' in detail:
        # New structured format from API Gateway
        user_id = detail['userId']
        http_method = detail['httpMethod']
        # Body can be either a string (needs parsing) or already a dict
        body_data = detail.get('body', {})
        if isinstance(body_data, str):
            body = json.loads(body_data) if body_data else {}
        else:
            body = body_data if body_data else {}
        request_id = detail.get('requestId')
    else:
        # Fallback: try to extract from the raw event detail
        # This handles cases where the entire request is in the detail
        user_id = detail.get('user_id') or detail.get('userId')
        http_method = detail.get('httpMethod') or eb_event.detail_type.split()[0]  # Extract from "POST Cart Operation"
        body = detail if not user_id else {}
        request_id = detail.get('requestId')
        
        if not user_id:
            raise ValueError("userId not found in event detail. Event detail keys: " + str(list(detail.keys())))
    
    logger.info(f"Processing {http_method} cart operation for user {user_id}")
    
    try:
        if http_method == 'POST':
            result = create_cart(user_id, body)
        elif http_method == 'PUT':
            result = update_cart(user_id, body)
        elif http_method == 'DELETE':
            result = delete_cart(user_id)
        else:
            raise ValueError(f"Unsupported HTTP method: {http_method}")
        
        # Publish cart event for other services
        publish_cart_event(http_method.lower(), user_id, result, request_id)
        
        metrics.add_metric(name="CartOperationSuccess", unit=MetricUnit.Count, value=1)
        return {'statusCode': 200, 'body': json.dumps(result, cls=DecimalEncoder)}
        
    except Exception as e:
        logger.error(f"Cart operation failed: {str(e)}")
        metrics.add_metric(name="CartOperationError", unit=MetricUnit.Count, value=1)
        raise

@tracer.capture_method
def create_cart(user_id: str, cart_data: dict) -> dict:
    cart_item = {
        'user_id': user_id,
        'items': cart_data.get('items', []),
        'total_amount': Decimal('0.00'),
        'item_count': 0,
        'created_at': datetime.now(timezone.utc).isoformat(),
        'updated_at': datetime.now(timezone.utc).isoformat()
    }
    
    # Calculate totals
    cart_item = calculate_cart_totals(cart_item)
    cart_table.put_item(Item=cart_item)
    
    logger.info(f"Cart created for user {user_id}")
    return cart_item

@tracer.capture_method
def update_cart(user_id: str, cart_data: dict) -> dict:
    response = cart_table.get_item(Key={'user_id': user_id})
    
    if 'Item' not in response:
        return create_cart(user_id, cart_data)
    
    cart_item = response['Item']
    cart_item['items'] = cart_data.get('items', cart_item['items'])
    cart_item['updated_at'] = datetime.now(timezone.utc).isoformat()
    
    cart_item = calculate_cart_totals(cart_item)
    logger.info(f"Updated cart item {json.dumps(cart_item, default=str)}")

    cart_table.put_item(Item=cart_item)
    
    logger.info(f"Cart updated for user {user_id}")
    return cart_item

@tracer.capture_method
def delete_cart(user_id: str) -> dict:
    cart_table.delete_item(Key={'user_id': user_id})
    logger.info(f"Cart deleted for user {user_id}")
    return {'user_id': user_id, 'status': 'deleted'}

def calculate_cart_totals(cart_item: dict) -> dict:
    items = cart_item.get('items', [])
    total_amount = Decimal('0.00')
    item_count = 0
    
    for item in items:
        quantity = Decimal(str(item.get('quantity', 0)))
        price = Decimal(str(item.get('price', 0)))
        
        # Ensure the item price and quantity are stored as Decimal
        item['price'] = price
        item['quantity'] = quantity
        
        total_amount += price * quantity
        item_count += int(quantity)
    
    cart_item['total_amount'] = total_amount
    cart_item['item_count'] = item_count
    return cart_item

def publish_cart_event(operation: str, user_id: str, cart_data: dict, request_id: str):
    try:
        eventbridge.put_events(
            Entries=[{
                'Source': 'CNS203.cart.completed',
                'DetailType': f'Cart {operation.title()}d',
                'Detail': json.dumps({
                    'user_id': user_id,
                    'operation': operation,
                    'cart_data': cart_data,
                    'request_id': request_id
                }, cls=DecimalEncoder),
                'EventBusName': os.environ.get('EVENT_BUS_NAME')
            }]
        )
    except Exception as e:
        logger.error(f"Failed to publish cart event: {e}")

